# Backend environment variables
# Copy this to .env and fill in the values

# ─── App ───────────────────────────────────────────────────────────────────────
APP_NAME=WealthPilot API
APP_ENV=production

# ─── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/wealthpilot
#
# Neon PostgreSQL (production):
DATABASE_URL=postgresql+psycopg://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Localhost is always allowed in addition to these.
FRONTEND_URL=https://money.pramodgoudar.com

# ─── Auth ──────────────────────────────────────────────────────────────────────
# The owner credentials used for the frontend login gate.
# These are checked in the React app (frontend-only auth).
# No backend auth middleware currently — all API routes are public.
# For production, these are set as VITE_ env vars in Vercel, not here.
OWNER_EMAIL=your@email.com
OWNER_PHONE=your_phone_number
