# Backend environment variables
# Copy this to .env and fill in the values

# ─── App ───────────────────────────────────────────────────────────────────────
APP_NAME=WealthPilot API
APP_ENV=production

# ─── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/wealthpilot
#
# Neon PostgreSQL (production):
DATABASE_URL=postgresql+psycopg://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Localhost is always allowed.
# Example:
# FRONTEND_URL=https://money.pramodgoudar.com,https://wealthpilot.vercel.app
FRONTEND_URL=https://money.pramodgoudar.com

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Owner credentials — checked server-side at login, never exposed to the browser.
OWNER_EMAIL=your@email.com
OWNER_PHONE=your_phone_number

# HMAC signing key for session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-hex-char-random-string

# Optional cookie overrides.
# Mode A: current Render backend domain
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true
# COOKIE_DOMAIN=
#
# Mode B: recommended custom API subdomain for better iOS Safari stability
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.money.pramodgoudar.com
COOKIE_SAMESITE=
COOKIE_SECURE=
COOKIE_DOMAIN=
